    "qualifyingQuiz": {
        "id": "route_quiz_v2",
        "questions": [
            {
                "id": "location",
                "type": "choice",
                "label": "Where are you based?",
                "help": "Some funders are restricted by geography.",
                "choices": [
                    {
                        "value": "england",
                        "label": "England"
                    },
                    {
                        "value": "scotland",
                        "label": "Scotland"
                    },
                    {
                        "value": "wales",
                        "label": "Wales"
                    },
                    {
                        "value": "ni",
                        "label": "Northern Ireland"
                    }
                ],
                "required": true
            },
            {
                "id": "who_are_you",
                "type": "choice",
                "label": "Who are you applying as?",
                "choices": [
                    {
                        "value": "individual",
                        "label": "An individual artist / practitioner"
                    },
                    {
                        "value": "collective",
                        "label": "A collective or group"
                    },
                    {
                        "value": "org",
                        "label": "An organisation (charity, CIC, etc.)"
                    }
                ],
                "required": true
            },
            {
                "id": "discipline",
                "type": "choice",
                "label": "What is your primary discipline?",
                "choices": [
                    {
                        "value": "visual",
                        "label": "Visual Arts"
                    },
                    {
                        "value": "music",
                        "label": "Music"
                    },
                    {
                        "value": "theatre",
                        "label": "Theatre"
                    },
                    {
                        "value": "dance",
                        "label": "Dance"
                    },
                    {
                        "value": "literature",
                        "label": "Literature"
                    },
                    {
                        "value": "combined",
                        "label": "Combined Arts / Multi-artform"
                    },
                    {
                        "value": "heritage",
                        "label": "Heritage / Museums / Archives"
                    },
                    {
                        "value": "film",
                        "label": "Film / Digital / Screen"
                    },
                    {
                        "value": "craft",
                        "label": "Craft & Design"
                    }
                ],
                "required": true
            },
            {
                "id": "q_goal",
                "type": "choice",
                "label": "What best describes your goal?",
                "choices": [
                    {
                        "value": "public_project",
                        "label": "A time-limited project for an audience / public outcome"
                    },
                    {
                        "value": "practice_dev",
                        "label": "My own development (skills, networks, research)"
                    },
                    {
                        "value": "heritage_project",
                        "label": "Saving, conserving, or celebrating heritage"
                    },
                    {
                        "value": "social_change",
                        "label": "Art for social change, equity, or participation"
                    }
                ],
                "required": true
            }
        ],
        "recommendations": [
            {
                "if": [
                    {
                        "questionId": "location",
                        "equals": "england"
                    },
                    {
                        "questionId": "q_goal",
                        "equals": "public_project"
                    }
                ],
                "routeId": "ace_project_grants"
            },
            {
                "if": [
                    {
                        "questionId": "location",
                        "equals": "england"
                    },
                    {
                        "questionId": "q_goal",
                        "equals": "practice_dev"
                    }
                ],
                "routeId": "ace_dycp"
            },
            {
                "if": [
                    {
                        "questionId": "location",
                        "equals": "scotland"
                    }
                ],
                "routeId": "creative_scotland_open_fund"
            },
            {
                "if": [
                    {
                        "questionId": "q_goal",
                        "equals": "heritage_project"
                    }
                ],
                "routeId": "nlhf_project_grants"
            },
            {
                "if": [
                    {
                        "questionId": "who_are_you",
                        "equals": "org"
                    },
                    {
                        "questionId": "q_goal",
                        "equals": "public_project"
                    }
                ],
                "routeId": "jerwood_arts_fund"
            },
            {
                "if": [
                    {
                        "questionId": "who_are_you",
                        "equals": "org"
                    },
                    {
                        "questionId": "q_goal",
                        "equals": "social_change"
                    }
                ],
                "routeId": "phf_arts_access"
            }
        ]
    }
