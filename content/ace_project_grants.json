            "id": "project_summary_300",
            "title": "Project summary (Max 300 chars)",
            "type": "paragraph",
            "requiredInputs": [
                "q_one_sentence",
                "q_target_audience",
                "q_format",
                "q_rough_dates"
            ],
            "template": [
                "{q_one_sentence} This project is for {q_target_audience} and will be delivered via {q_format} between {q_rough_dates}."
